# Environment and secrets
.env
.env.local
.env.*.local

# All writable runtime state: per-account config, daily stats, and the Chrome
# profiles used for captcha solving. One directory to ignore, back up, or
# delete. Override the location with DATA_DIR.
var/

# Go build output
/sempatowo
/sempatowo.exe
*.exe
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# IDE / OS
.idea/
.vscode/
*.code-workspace
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
