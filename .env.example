# USER account token only — NOT a bot token from https://discord.com/developers/applications
# Multiple accounts: separate with commas, e.g. "TOKEN1,TOKEN2"
TOKEN="YOUR_USER_ACCOUNT_TOKEN_HERE"

# Where all writable state lives: config/, data/, browser-profiles/ (default ./var)
# DATA_DIR="./var"

# OCR.space API key for auto-quest image parsing (free key: https://ocr.space/ocrapi/freekey)
# Defaults to the shared "helloworld" test key, which is heavily rate-limited.
# OCR_API_KEY="your_ocr_space_key"

# Optional: automatic OwO captcha solving
# CAPTCHA_API_KEY="your_solver_api_key"
# CAPTCHA_SERVICE="capsolver"   # capsolver (default), capmonster, or 2captcha
# CAPTCHA_SOLVE_TIMEOUT=90      # seconds

# Isolated browser per account (default true)
# BROWSER_ISOLATED=true
# BROWSER_PROFILES_DIR="./var/browser-profiles"
# BROWSER_EXECUTABLE="C:\Program Files\Google\Chrome\Application\chrome.exe"
# BROWSER_EXTENSION_ID=""
# BROWSER_EXTENSION_PATH=""

# Desktop notification on captcha (default on; set false to disable)
# NOTIFICATIONS=true

# Disable coloured log output (any non-empty value)
# NO_COLOR=1

# Everything above is read and validated once at startup:
#   go run ./cmd/sempatowo -check-config
