# USER account token only — NOT a bot token from https://discord.com/developers/applications
# Multiple accounts: separate with commas, e.g. "TOKEN1,TOKEN2"
TOKEN="YOUR_USER_ACCOUNT_TOKEN_HERE"

# Optional: automatic OwO captcha solving (capsolver, capmonster, or 2captcha)
# CAPTCHA_API_KEY="your_solver_api_key"
# CAPTCHA_SERVICE="capsolver"
# CAPTCHA_SOLVE_TIMEOUT=90

# Isolated browser per account (default true)
# BROWSER_ISOLATED=true
# BROWSER_PROFILES_DIR="./browser-profiles"
# BROWSER_EXECUTABLE="C:\Program Files\Google\Chrome\Application\chrome.exe"

# Desktop notification on captcha (default on; set false to disable)
# NOTIFICATIONS=true

# OCR.space API key for auto-quest image parsing (free key: https://ocr.space/ocrapi/freekey)
# Set ocrApi in config JSON, or use default "helloworld" for testing (rate-limited)
